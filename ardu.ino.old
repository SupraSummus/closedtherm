#include <WiFi.h>
#include <WiFiClient.h>
#include <WebServer.h>
#include "time.h"
#include <ArduinoJson.h>
#include <OneWire.h>
#include <DallasTemperature.h>

extern const char* ssid;
extern const char* password;
#include "creds.h"

const char* host = "hydro";

const char* ntpServer1 = "pool.ntp.org";
const char* ntpServer2 = "time.nist.gov";
const long  gmtOffset_sec = 0;
const int   daylightOffset_sec = 0;

WebServer server(80);

const int ONE_WIRE_BUS = 26;
const int PRESSURE_PIN = 32;

const uint8_t sensor1_address[8] = {0x28, 0x00, 0x87, 0x56, 0xB5, 0x01, 0x3C, 0x05};
const uint8_t sensor2_address[8] = {0x28, 0xB2, 0x78, 0x56, 0xB5, 0x01, 0x3C, 0xA5};
const uint8_t sensor3_address[8] = {0x28, 0x9F, 0x3D, 0x02, 0x2D, 0x19, 0x01, 0x60};

OneWire oneWire(ONE_WIRE_BUS);	
DallasTemperature sensors(&oneWire);


void handleRoot() {
  Serial.println("Handling HTTP request");

  sensors.requestTemperatures();

  time_t now;
  now = time(nullptr);

  StaticJsonDocument<512> doc;
  doc["host"] = host;
  doc["time"] = now;
  doc["rssi"] = WiFi.RSSI();
  doc["pressure"] = analogRead(PRESSURE_PIN);
  doc["temp1"] = sensors.getTempC(sensor1_address);
  doc["temp2"] = sensors.getTempC(sensor2_address);
  doc["temp3"] = sensors.getTempC(sensor3_address);
  String output;
  serializeJsonPretty(doc, output);

  server.send(200, "application/json", output);
}

void dump_sensors_addresses () {
  int deviceCount = sensors.getDeviceCount();
  Serial.println("Scanning one wire bus, found " + String(deviceCount) + " devices");
  for (int i = 0; i < deviceCount; i++) {
    DeviceAddress deviceAddress;
    sensors.getAddress(deviceAddress, i);
    Serial.print("Device ");
    Serial.print(i);
    Serial.print(" address: ");
    for (uint8_t j = 0; j < 8; j++) {
      Serial.print("0x");
      if (deviceAddress[j] < 0x10) Serial.print("0");
      Serial.print(deviceAddress[j], HEX);
      if (j < 7) Serial.print(", ");
    }
    Serial.println();
  }
}

void setup(void) {
  Serial.begin(115200);

  // configure temperature sensor
  Serial.println("Configuring dalls temp on pin " + String(ONE_WIRE_BUS));
  sensors.begin();
  dump_sensors_addresses();

  // config pressure sensor
  Serial.println("Configuring pressure sensor on pin " + String(PRESSURE_PIN));
  pinMode(PRESSURE_PIN, INPUT);
  analogSetAttenuation(ADC_0db);

  // configure wifi
  WiFi.mode(WIFI_STA);
  WiFi.begin(ssid, password);
  Serial.println("");
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("");
  Serial.print("Connected to ");
  Serial.println(ssid);
  Serial.print("IP address: ");
  Serial.println(WiFi.localIP());

  // configure time
  configTime(gmtOffset_sec, daylightOffset_sec, ntpServer1, ntpServer2);
  Serial.println("\nWaiting for time");
  while (!time(nullptr)) {
    Serial.print(".");
    delay(1000);
  }
  Serial.println("");
  Serial.print("Time: ");
  Serial.println(time(nullptr));

  // configure server
  server.on("/", handleRoot);
  server.begin();
  Serial.println("HTTP server started");
}

void loop(void) {
  server.handleClient();
  delay(2);//allow the cpu to switch to other tasks

  // int pressure = analogRead(PRESSURE_PIN);
  // Serial.println("Pressure: " + String(pressure));
  // delay(1000);
}
